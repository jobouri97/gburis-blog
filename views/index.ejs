<body>
    <%- include("partials/header") %>

        <main class="container mt-5">
            <% if(locals.blogs && blogs.length===0) { %>
                <div class="empty-state">
                    <h1>No blogs yet.</h1>
                    <p>Start by creating your first blog post.</p>
                    <a href="/addBlog" class="btn btn-primary">Add Blog</a>
                </div>
                <% } %>
                    <% if (locals.blogs && blogs.length> 0) { %>
                        <div class="row row-cols-1 row-cols-md-3 mb-3 text-center">

                            <% blogs.forEach(function(blog, index) { %>
                                <div class="col mb-4">
                                    <div class="card mb-2 rounded-3 shadow-sm border-primary">
                                        <div class="card-header py-3 text-bg-primary border-primary">
                                            <h4 class="my-0 fw-normal">
                                                <%= blog.author %>
                                            </h4>
                                        </div>

                                        <div class="card-body">
                                            <h1 class="card-title pricing-card-title">
                                                <%= blog.title %>
                                            </h1>
                                            <p>
                                                <%= blog.details %>
                                            </p>

                                            <div class="container-buttons">
                                                <a href="/edit/<%= index %>" class="btn btn-warning">Edit</a>
                                                <a href="/remove/<%= index %>" class="btn btn-danger">Remove</a>
                                                <a href="/view/<%= index %>" class="btn btn-primary">View</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>

                        </div>
                        <% } %>
        </main>
    <%- include("partials/footer") %>

</body>